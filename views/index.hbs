<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{meta.title}}</title>
  <meta name="description" content="{{meta.description}}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,400&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-[#f6faf9] font-sans text-[#142b28]">

  <!-- ─── NAV ─────────────────────────────────────────────────────── -->
  <nav
    x-data="{ scrolled: false, open: false }"
    x-init="window.addEventListener('scroll', () => scrolled = window.scrollY > 30)"
    :class="scrolled ? 'shadow-md' : ''"
    class="fixed top-0 left-0 right-0 z-50 bg-[rgba(246,250,249,0.97)] backdrop-blur-sm transition-shadow duration-300"
  >
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="#inicio" class="flex items-center gap-2">
        <img src="/images/logo.png" alt="Santuario Clafira" class="h-10 w-10 object-contain" />
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-8">
        {{#each nav.links}}
        <li>
          <a href="{{lookup ../nav.hrefs @index}}"
             class="text-sm font-semibold text-[#142b28] hover:text-teal transition-colors">
            {{this}}
          </a>
        </li>
        {{/each}}
      </ul>

      <!-- Right side: lang toggle + CTA -->
      <div class="hidden md:flex items-center gap-4">
        <a href="{{nav.langHref}}"
           class="text-xs font-bold text-[#142b28] border border-[#3d6b64]/30 rounded-full px-3 py-1 hover:border-teal hover:text-teal transition-colors">
          {{nav.langToggle}}
        </a>
        <a href="#donar" class="btn-primary text-sm py-2 px-6">
          {{nav.cta}}
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button @click="open = !open" class="md:hidden p-2 text-[#142b28]" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path x-show="open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div x-show="open" x-transition class="md:hidden bg-[rgba(246,250,249,0.98)] border-t border-teal-pale px-6 pb-6">
      <ul class="flex flex-col gap-4 pt-4">
        {{#each nav.links}}
        <li>
          <a href="{{lookup ../nav.hrefs @index}}" @click="open = false"
             class="block text-sm font-semibold text-[#142b28] hover:text-teal transition-colors">
            {{this}}
          </a>
        </li>
        {{/each}}
      </ul>
      <div class="mt-4 flex gap-3">
        <a href="{{nav.langHref}}" class="text-xs font-bold border border-[#3d6b64]/30 rounded-full px-3 py-1">{{nav.langToggle}}</a>
        <a href="#donar" class="btn-primary text-sm py-2 px-5">{{nav.cta}}</a>
      </div>
    </div>
  </nav>

  <!-- ─── HERO ─────────────────────────────────────────────────────── -->
  <section id="inicio" class="min-h-screen bg-[#e8f5f3] flex items-center relative overflow-hidden pt-16">
    <!-- Dot texture background -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.04]" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="hero-dots" patternUnits="userSpaceOnUse" width="40" height="40">
          <circle cx="20" cy="20" r="2" fill="#1a3530"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-dots)"/>
    </svg>
    <!-- Decorative circles -->
    <div class="absolute -right-44 top-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-teal opacity-[0.08]"></div>
    <div class="absolute right-16 top-1/2 -translate-y-1/2 w-[460px] h-[460px] rounded-full border-2 border-teal opacity-[0.15]"></div>

    <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-16 items-center w-full relative">
      <!-- Text -->
      <div>
        <div class="inline-flex items-center gap-2 bg-teal/10 rounded-full px-4 py-1.5 mb-7">
          <div class="w-2 h-2 rounded-full bg-teal"></div>
          <span class="text-xs font-bold text-teal tracking-widest uppercase">{{hero.badge}}</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-[#1a3530] leading-tight mb-6">
          {{hero.headline}}
        </h1>
        <p class="text-lg text-[#4a7a72] leading-relaxed mb-10 max-w-lg">
          {{hero.sub}}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#nosotros" class="bg-teal text-white font-bold py-3.5 px-8 rounded-full hover:bg-teal-dark hover:-translate-y-0.5 transition-all">
            {{hero.cta1}}
          </a>
          <a href="#donar" class="border-2 border-[#1a3530]/40 text-[#1a3530] font-bold py-3.5 px-8 rounded-full hover:border-[#1a3530] hover:-translate-y-0.5 transition-all">
            {{hero.cta2}}
          </a>
        </div>
        <!-- Stats -->
        <div class="flex flex-wrap gap-10 mt-14">
          {{#each hero.stats}}
          <div>
            <div class="font-serif text-4xl font-bold text-teal">{{this.num}}</div>
            <div class="text-xs text-[#4a7a72] tracking-wide mt-1">{{this.label}}</div>
          </div>
          {{/each}}
        </div>
      </div>

      <!-- Hero image + floating card -->
      <div class="relative hidden md:block">
        <div class="rounded-2xl overflow-hidden aspect-[4/5]">
          <img
            src="/images/animales/hero-caballo.jpg"
            alt="Yegua rescatada en el Santuario Clafira"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Floating rescue card -->
        <div class="absolute -bottom-5 -left-6 bg-white rounded-2xl p-4 shadow-lg border border-teal/10">
          <div class="text-xs text-[#7aaba4] mb-1">{{hero.lastRescue.label}}</div>
          <div class="font-serif font-bold text-[#142b28] text-base">{{hero.lastRescue.name}}</div>
          <div class="text-xs text-teal mt-1">{{hero.lastRescue.time}}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ABOUT ─────────────────────────────────────────────────────── -->
  <section id="nosotros" class="bg-[#f6faf9] py-24 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center">
      <!-- Photo grid -->
      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-2xl overflow-hidden row-span-2 aspect-[3/4]">
          <img
            src="/images/animales/nosotros-burro-madre.jpg"
            alt="Burro bebé con su madre en el Santuario Clafira"
            class="w-full h-full object-cover object-center"
          />
        </div>
        <div class="rounded-2xl overflow-hidden aspect-[4/3]">
          <img
            src="/images/animales/nosotros-vaca.jpg"
            alt="Vaca rescatada en el Santuario Clafira"
            class="w-full h-full object-cover object-center"
          />
        </div>
        <div class="rounded-2xl overflow-hidden aspect-[4/3]">
          <img
            src="/images/animales/nosotros-ciervos.jpg"
            alt="Ciervos alimentándose en el Santuario Clafira"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>

      <!-- Text -->
      <div>
        <div class="section-label">{{about.sectionLabel}}</div>
        <h2 class="section-title text-[#142b28] mb-6">{{about.title}}</h2>
        <p class="text-[#3d6b64] leading-relaxed mb-4">{{about.p1}}</p>
        <p class="text-[#3d6b64] leading-relaxed mb-10">{{about.p2}}</p>
        <div class="flex flex-col gap-5">
          {{#each about.values}}
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-teal-pale flex items-center justify-center flex-shrink-0">
              <div class="w-3 h-3 rounded-full bg-teal"></div>
            </div>
            <div>
              <div class="font-bold text-[#142b28] text-sm mb-0.5">{{this.title}}</div>
              <div class="text-sm text-[#3d6b64] leading-relaxed">{{this.desc}}</div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ANIMALS ─────────────────────────────────────────────────────── -->
  <section id="animales" class="bg-[#edf6f4] py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-14">
        <div class="section-label">{{animals.sectionLabel}}</div>
        <h2 class="section-title text-[#142b28] mb-4">{{animals.title}}</h2>
        <p class="text-[#3d6b64] text-lg max-w-xl mx-auto">{{animals.sub}}</p>
      </div>

      <!-- Animal cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {{#each animals.list}}
        <div
          x-data="{ open: false }"
          @click="open = !open"
          :class="open ? 'ring-2 ring-teal shadow-[0_8px_40px_rgba(61,158,142,0.2)]' : 'shadow-md hover:-translate-y-1'"
          class="bg-white rounded-2xl overflow-hidden cursor-pointer transition-all duration-200"
        >
          <!-- Animal placeholder image -->
          <div class="aspect-[4/3] bg-teal-pale flex items-center justify-center">
            <div class="text-center">
              <div class="text-7xl">{{this.emoji}}</div>
              <p class="text-xs text-[#7aaba4] mt-2 font-medium">{{this.name}}</p>
            </div>
          </div>
          <!-- Card content -->
          <div class="p-5">
            <div class="flex items-baseline gap-2 mb-2">
              <span class="font-serif font-bold text-xl text-[#142b28]">{{this.name}}</span>
              <span class="text-sm text-teal font-semibold">{{this.species}}</span>
            </div>
            <div x-show="open" x-transition class="text-sm text-[#3d6b64] leading-relaxed border-t border-teal-pale pt-3 mt-2">
              {{this.story}}
            </div>
            <div x-show="!open" class="text-sm text-teal mt-1">
              {{#if ../isEs}}Ver historia →{{else}}See story →{{/if}}
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-12">
        <a href="#donar" class="bg-teal-pale text-teal font-bold py-3 px-8 rounded-full hover:bg-teal/20 transition-colors inline-block">
          {{animals.cta}}
        </a>
      </div>
    </div>
  </section>

  <!-- ─── DONATE ─────────────────────────────────────────────────────── -->
  <section id="donar" class="bg-teal py-24 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-20 items-center">
      <!-- Left copy -->
      <div>
        <div class="text-xs font-bold text-white/60 tracking-widest uppercase mb-4">{{donate.sectionLabel}}</div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-5">
          {{donate.title}}
        </h2>
        <p class="text-white/75 text-base leading-relaxed mb-8">{{donate.sub}}</p>
        <div class="flex flex-wrap gap-6">
          {{#each donate.impacts}}
          <div class="bg-white/10 rounded-xl p-4">
            <div class="font-serif font-bold text-lg text-white">{{this.amount}}</div>
            <div class="text-sm text-white/70 mt-1">{{this.label}}</div>
          </div>
          {{/each}}
        </div>
      </div>

      <!-- Donation form -->
      <div
        x-data="{
          freq: 'monthly',
          amount: 5000,
          custom: '',
          get display() { return this.custom || this.amount; }
        }"
        class="bg-white rounded-2xl p-9 shadow-xl"
      >
        <!-- Frequency -->
        <div class="text-sm font-bold text-[#3d6b64] mb-4">{{donate.freqLabel}}</div>
        <div class="flex gap-2 mb-7">
          <button
            @click="freq = 'monthly'"
            :class="freq === 'monthly' ? 'border-teal bg-teal-pale text-teal' : 'border-teal-pale text-[#7aaba4]'"
            class="flex-1 py-2.5 border-2 rounded-full font-bold text-sm transition-all">
            {{#if isEs}}Mensual{{else}}Monthly{{/if}}
          </button>
          <button
            @click="freq = 'once'"
            :class="freq === 'once' ? 'border-teal bg-teal-pale text-teal' : 'border-teal-pale text-[#7aaba4]'"
            class="flex-1 py-2.5 border-2 rounded-full font-bold text-sm transition-all">
            {{#if isEs}}Única vez{{else}}One time{{/if}}
          </button>
        </div>

        <!-- Amount presets -->
        <div class="text-sm font-bold text-[#3d6b64] mb-3">{{donate.amountLabel}}</div>
        <div class="grid grid-cols-2 gap-2 mb-3">
          <button
            @click="amount = 2000; custom = ''"
            :class="amount === 2000 && !custom ? 'border-teal bg-teal-pale text-teal' : 'border-teal-pale text-[#3d6b64]'"
            class="py-3 border-2 rounded-xl font-bold text-sm transition-all">$2.000</button>
          <button
            @click="amount = 5000; custom = ''"
            :class="amount === 5000 && !custom ? 'border-teal bg-teal-pale text-teal' : 'border-teal-pale text-[#3d6b64]'"
            class="py-3 border-2 rounded-xl font-bold text-sm transition-all">$5.000</button>
          <button
            @click="amount = 10000; custom = ''"
            :class="amount === 10000 && !custom ? 'border-teal bg-teal-pale text-teal' : 'border-teal-pale text-[#3d6b64]'"
            class="py-3 border-2 rounded-xl font-bold text-sm transition-all">$10.000</button>
          <button
            @click="amount = 20000; custom = ''"
            :class="amount === 20000 && !custom ? 'border-teal bg-teal-pale text-teal' : 'border-teal-pale text-[#3d6b64]'"
            class="py-3 border-2 rounded-xl font-bold text-sm transition-all">$20.000</button>
        </div>
        <input
          type="number"
          x-model="custom"
          placeholder="{{donate.customPlaceholder}}"
          class="w-full px-4 py-3 border-2 border-teal-pale rounded-xl text-sm text-[#142b28] bg-[#f6faf9] focus:outline-none focus:border-teal transition-colors mb-5"
        />
        <button
          class="w-full bg-teal hover:bg-teal-dark text-white font-extrabold py-4 rounded-full text-base transition-colors"
        >
          {{#if isEs}}Donar{{else}}Donate{{/if}}
          <span x-text="'$' + Number(display).toLocaleString() + ' CLP'"></span>
        </button>
        <p class="text-xs text-[#7aaba4] text-center mt-3">{{donate.secure}}</p>
      </div>
    </div>
  </section>

  <!-- ─── VOLUNTEER ─────────────────────────────────────────────────────── -->
  <section id="voluntariado" class="bg-[#2c3a30] py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-xs font-bold text-white/50 tracking-widest uppercase mb-4">{{volunteer.sectionLabel}}</div>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-5">{{volunteer.title}}</h2>
      <p class="text-white/75 text-lg leading-relaxed max-w-xl mx-auto mb-12">{{volunteer.sub}}</p>

      <!-- Social cards -->
      <div class="flex flex-wrap gap-5 justify-center mb-14">
        {{#each volunteer.socials}}
        <a
          href="{{this.href}}"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white/10 border border-white/15 rounded-2xl px-9 py-7 flex flex-col items-center gap-3 min-w-[180px] hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(61,158,142,0.3)] transition-all no-underline"
        >
          {{#if (eq this.icon "instagram")}}
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="2" width="20" height="20" rx="6" stroke="#3d9e8e" stroke-width="2"/>
            <circle cx="12" cy="12" r="4" stroke="#3d9e8e" stroke-width="2"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="#3d9e8e"/>
          </svg>
          {{else if (eq this.icon "facebook")}}
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="2" width="20" height="20" rx="6" stroke="#3d9e8e" stroke-width="2"/>
            <path d="M13 21v-8h2.5l.5-3H13V8.5c0-.83.67-1.5 1.5-1.5H16V4h-2a4 4 0 0 0-4 4v2H8v3h2v8" stroke="#3d9e8e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{else}}
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="2" width="20" height="20" rx="6" stroke="#3d9e8e" stroke-width="2"/>
            <path d="M9 12a3 3 0 1 0 3 3V7a4 4 0 0 0 4 4" stroke="#3d9e8e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{/if}}
          <div class="font-extrabold text-base text-white">{{this.name}}</div>
          <div class="text-sm text-white/60">{{this.handle}}</div>
        </a>
        {{/each}}
      </div>

      <!-- Volunteer photo placeholder -->
      <div class="rounded-2xl overflow-hidden max-w-2xl mx-auto aspect-[16/7] bg-white/[0.06] flex items-center justify-center">
        <div class="text-center">
          <div class="text-6xl mb-2">🤝</div>
          <p class="text-white/40 text-sm">Foto jornada de voluntariado</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FOOTER ─────────────────────────────────────────────────────── -->
  <footer class="bg-[#f6faf9] border-t border-teal-pale py-12 px-6">
    <div class="max-w-7xl mx-auto flex flex-wrap justify-between items-center gap-6">
      <a href="#inicio">
        <img src="/images/logo.png" alt="Santuario Clafira" class="h-12 w-12 object-contain" />
      </a>
      <div class="text-sm text-[#7aaba4] text-center">
        {{footer.location}}<br/>
        <a href="{{footer.instagram}}" target="_blank" rel="noopener" class="text-teal hover:text-teal-dark transition-colors">
          {{footer.handle}}
        </a>
      </div>
      <div class="text-xs text-[#7aaba4]">
        © {{footer.year}} Santuario Clafira · {{footer.copyright}}
      </div>
    </div>
  </footer>

</body>
</html>
