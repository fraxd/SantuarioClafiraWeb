{
  "name": "santuario-clafira",
  "version": "1.0.0",
  "description": "Sitio web oficial de Santuario Clafira - Refugio de animales de granja en Limache, Chile",
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/globals.css -o ./public/css/styles.css",
    "build:css:watch": "tailwindcss -i ./src/css/globals.css -o ./public/css/styles.css --watch",
    "build": "npm run build:css && nest build",
    "start": "npm run build:css && nest start",
    "start:dev": "concurrently \"npm run build:css:watch\" \"nest start --watch\"",
    "start:prod": "node dist/main",
    "build:static": "npm run build:css && nest build && node scripts/build-static.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "hbs": "^4.2.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/hbs": "^4.0.4",
    "@types/node": "^20.3.1",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.1.3"
  }
}
